# local | staging | production. Production mode makes launch checks strict.
DOUBOW_ENVIRONMENT=local
# Comma-separated origins, OR a JSON array. Bare hostnames get https:// (localhost → http://).
# Examples:
# DOUBOW_CORS_ALLOW_ORIGINS=http://localhost:3000,https://doubau.vercel.app
# DOUBOW_CORS_ALLOW_ORIGINS=["http://localhost:3000","https://doubau.vercel.app"]
DOUBOW_CORS_ALLOW_ORIGINS=http://localhost:3000,https://doubau.vercel.app
# From the host, Compose publishes Postgres on 5433 (see docker-compose.yml). Inside Compose, use hostname `postgres` and port 5432.
DOUBOW_DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5433/doubow
# Railway injects DATABASE_URL automatically. The API will fall back to it if
# DOUBOW_DATABASE_URL is unset (or points to localhost while running inside a container).
# DATABASE_URL=postgresql://...
DOUBOW_JWT_SECRET=dev_only_change_me
# Local dev (running API outside Docker):
DOUBOW_REDIS_URL=redis://localhost:6379/0
# Railway injects REDIS_URL automatically for Redis plugins. The API/Celery
# will fall back to it when DOUBOW_REDIS_URL is unset (or points to local/Docker
# Redis while running inside a container).
# REDIS_URL=redis://...

# OpenAI — résumé embeddings (Phase 1). Worker sets status EMBEDDED when set.
# Leave unset for parse-only (PARSED); required for full Phase 1 completion in prod.
# DOUBOW_OPENAI_API_KEY=sk-...
# Common alias supported as a fallback (for platforms that already set OPENAI_API_KEY):
# OPENAI_API_KEY=sk-...
# DOUBOW_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# DOUBOW_EMBEDDING_DIMENSIONS=1536
# DOUBOW_EMBEDDING_MAX_INPUT_CHARS=30000
# DOUBOW_OPENAI_CHAT_MODEL=gpt-4o-mini
# DOUBOW_SCRAPE_MAX_REQUESTS_PER_HOST_PER_MINUTE=30
# DOUBOW_SCRAPE_RSS_MAX_ENTRIES=25

# Object key prefix for résumés (must match Terraform `resume_object_prefix`; IAM policy scope).
DOUBOW_S3_RESUME_OBJECT_PREFIX=resumes
# Scraped job HTML keys: `{prefix}/{url_hash}.html` (must match Terraform `job_html_object_prefix`).
# DOUBOW_S3_JOB_HTML_PREFIX=job-html

# Remote OK ingest (optional v1 global-remote segment). Public JSON API; honor their attribution ToS in UI.
# DOUBOW_REMOTEOK_API_URL=https://remoteok.com/api
# DOUBOW_REMOTEOK_INGEST_MAX_JOBS=100

# Content dedup: Redis key TTL per ``hash(title|company|location)`` per listing_source (seconds, default 48h).
# DOUBOW_JOB_CONTENT_FINGERPRINT_TTL_SECONDS=172800

# Freshness: hide jobs older than N days by default (posted_at else created_at).
# DOUBOW_JOBS_STALE_AFTER_DAYS=30

# Adzuna API (developer.adzuna.com) — legacy/manual provider. Scheduled catalog ingest now uses JSearch + Remote OK.
# DOUBOW_ADZUNA_APP_ID=
# DOUBOW_ADZUNA_APP_KEY=
# DOUBOW_ADZUNA_COUNTRY_CODE=gb
# Optional Adzuna keyword search (any sector). Leave unset for broad results, or e.g. nurse, sales manager.
# DOUBOW_ADZUNA_SEARCH_WHAT=
# DOUBOW_ADZUNA_MAX_RESULTS=50

# --- Legal multi-board job APIs (no HTML scraping of LinkedIn/Indeed/Glassdoor) ---
# Catalog ingest is a shared pool (not per signed-in user). Cron uses only env defaults below.
# For a résumé-shaped query without hard-coding env: POST /jobs/ingest/jsearch
# with JSON {"resume_user_id":"<uuid>"} (ingestion admin), or set profile goals.job_search_query and pass that user.
# JSearch (RapidAPI): Indeed / LinkedIn / Glassdoor / ZipRecruiter-style results via one JSON API.
# https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch — subscribe, then set:
# DOUBOW_JSEARCH_RAPIDAPI_KEY=
# Optional: one RapidAPI application key for several APIs — used if JSearch-specific key is unset:
# DOUBOW_RAPIDAPI_KEY=
# DOUBOW_JSEARCH_RAPIDAPI_HOST=jsearch.p.rapidapi.com
# Job Search endpoint: ``search-v2`` (GET /search-v2) or ``search`` (GET /search) — RapidAPI “Job Search V2” vs “Job Search”.
# DOUBOW_JSEARCH_JOB_SEARCH_ENDPOINT=search-v2
# Optional ISO language for search (empty = omit; API uses primary language for country).
# DOUBOW_JSEARCH_LANGUAGE=en
# Optional keyword string for cron/bootstrap when no per-request body is used (empty → diversified broad defaults).
# DOUBOW_JSEARCH_QUERY=
# Optional comma/newline/pipe-separated broad queries for scheduled ingest. Leave empty to use built-in cross-field seeds
# (customer service, sales, marketing, operations, admin, HR, finance, healthcare, education, PM, design, engineering, tech, data).
# DOUBOW_JSEARCH_QUERIES=
# DOUBOW_JSEARCH_COUNTRY=us
# DOUBOW_JSEARCH_DATE_POSTED=all
# DOUBOW_JSEARCH_NUM_PAGES=1
# DOUBOW_JSEARCH_INGEST_MAX_JOBS=60
# Same API key/host also powers GET /job-details, /estimated-salary, /company-job-salary (see ``app.jobs.providers.jsearch``).
# Catalog feed tie-break + SQL candidate ordering prefer RapidAPI ``jsearch`` first (see ``catalog_listing_source_priority_rank``).
#
# Active Jobs DB (RapidAPI / Fantastic Jobs) — legacy/manual supplemental ATS + career-site feed (GET /active-ats-1h, etc.):
# https://rapidapi.com/fantastic-jobs-fantastic-jobs-default/api/active-jobs-db
# DOUBOW_ACTIVE_JOBS_DB_RAPIDAPI_KEY=
# DOUBOW_ACTIVE_JOBS_DB_RAPIDAPI_HOST=active-jobs-db.p.rapidapi.com
# DOUBOW_ACTIVE_JOBS_DB_PATH=/active-ats-1h
# Lucene-style filters (see RapidAPI params). Leave title empty for broad hourly ATS coverage.
# Example title (phrase) only when intentionally narrowing: DOUBOW_ACTIVE_JOBS_DB_TITLE_FILTER="Project Manager"
# Example location filter: quoted regions joined with OR — see Active Jobs DB ``location_filter`` docs on RapidAPI.
# DOUBOW_ACTIVE_JOBS_DB_DESCRIPTION_TYPE=text
# DOUBOW_ACTIVE_JOBS_DB_INGEST_MAX_JOBS=100
#
# SerpAPI Google Jobs engine (JSON) — legacy/manual fallback now replaced by JSearch for scheduled ingest:
# DOUBOW_SERPAPI_API_KEY=
# DOUBOW_SERPAPI_GOOGLE_JOBS_QUERY=
# DOUBOW_SERPAPI_GOOGLE_JOBS_LOCATION=
# DOUBOW_SERPAPI_GOOGLE_JOBS_HL=en
# DOUBOW_SERPAPI_INGEST_MAX_JOBS=60
#
# Glassdoor Real-time (RapidAPI) — e.g. GET /companies/interview-details?interviewId=…
# https://rapidapi.com (search “glassdoor real time”) — subscribe, then set:
# DOUBOW_GLASSDOOR_REALTIME_RAPIDAPI_KEY=
# DOUBOW_GLASSDOOR_REALTIME_RAPIDAPI_HOST=glassdoor-real-time.p.rapidapi.com
# Paths are configurable because RapidAPI endpoint labels can vary by product version/plan.
# Verify these against the RapidAPI “Endpoints” tab for your subscription.
# DOUBOW_GLASSDOOR_REALTIME_CONVERSATIONS_PATH=/conversations/search
# DOUBOW_GLASSDOOR_REALTIME_JOBS_PATH=/jobs/search
# DOUBOW_GLASSDOOR_REALTIME_JOB_DETAILS_PATH=/jobs/details
# DOUBOW_GLASSDOOR_REALTIME_COMPANIES_PATH=/companies/search
# DOUBOW_GLASSDOOR_REALTIME_COMPANY_DETAILS_PATH=/companies/details
# DOUBOW_GLASSDOOR_REALTIME_COMPANY_REVIEWS_PATH=/companies/reviews
# DOUBOW_GLASSDOOR_REALTIME_COMPANY_INTERVIEWS_PATH=/companies/interviews
# DOUBOW_GLASSDOOR_REALTIME_INTERVIEW_DETAILS_PATH=/companies/interview-details
# DOUBOW_GLASSDOOR_REALTIME_SALARIES_PATH=/salaries/search
# Authenticated API: GET /integrations/glassdoor/companies/interview-details?interview_id=19018219
#
# Job Opening Analyzer (RapidAPI) — POST /compute_similarity JSON { pivot, texts[] }
# https://rapidapi.com (search “job opening analyzer”) — subscribe, then set:
# DOUBOW_JOB_OPENING_ANALYZER_RAPIDAPI_KEY=
# DOUBOW_JOB_OPENING_ANALYZER_RAPIDAPI_HOST=job-opening-analyzer.p.rapidapi.com
# DOUBOW_JOB_OPENING_ANALYZER_COMPUTE_SIMILARITY_PATH=/compute_similarity
# Optional caps (characters / count) before calling upstream:
# DOUBOW_JOB_OPENING_ANALYZER_MAX_PIVOT_CHARS=48000
# DOUBOW_JOB_OPENING_ANALYZER_MAX_TEXTS=32
# DOUBOW_JOB_OPENING_ANALYZER_MAX_TEXT_CHARS_EACH=48000
# Authenticated API: POST /integrations/job-opening-analyzer/compute-similarity
#
# Batch RSS: comma / newline / pipe-separated public RSS or Atom URLs → each enqueues ``scrape_rss_feed``.
# DOUBOW_JOB_BOARD_RSS_URLS=

# Catalog ingest automation (optional):
# Shared secret for POST /jobs/cron/queue-ingest and POST /jobs/cron/clear-catalog — header X-Doubow-Cron-Secret.
# Generate with: openssl rand -hex 32
# DOUBOW_CRON_INGEST_SECRET=
# Extra Celery Beat schedule: hourly Remote OK at :17 UTC (needs worker + Redis; complements daily beat below).
# DOUBOW_INGEST_BEAT_HOURLY_REMOTEOK=false
# First-deploy bootstrap: queue JSearch + Remote OK ingest once (Redis NX lock across replicas).
# DOUBOW_BOOTSTRAP_INGEST_ON_STARTUP=false

# Single Railway/Docker container (optional): run worker + beat next to uvicorn (scripts/start.sh).
# DOUBOW_START_WORKER_IN_API=false
# DOUBOW_START_BEAT_IN_API=false
# DOUBOW_WORKER_CONCURRENCY=2

# Scrapling / Greenhouse / JSON-LD ingest (optional). These use unprefixed names
# so you can paste a Scrapling preset directly into the API service env.
# SCRAPLING_ENABLED=false
# SCRAPLING_FIXTURE_JSON_PATH=
# SCRAPLING_BUNDLE_FIXTURE=false
# SCRAPLING_CATALOG_IN_PRESET=true
# SCRAPLING_TIMEOUT_S=60
# SCRAPLING_AUTO_GREENHOUSE_BOARD_SEEDS=true
# SCRAPLING_GREENHOUSE_SEED_JOBS_PER_BOARD=5
# SCRAPLING_SEED_URLS=https://job-boards.greenhouse.io/yourco/jobs/123
#
# Public ATS JSON (no auth) — one URL per line / comma-separated (same list as Greenhouse seeds):
# Greenhouse: https://boards-api.greenhouse.io/v1/boards/{company}/jobs (handled via board slug from any GH URL)
# Lever:      https://api.lever.co/v0/postings/{site}?mode=json  or  https://jobs.lever.co/{site}
# Ashby:      https://api.ashbyhq.com/posting-api/job-board/{company}?includeCompensation=false
# Workday:    https://{tenant}.{shard}.myworkdayjobs.com/wday/cxs/{tenant}/{CareerSite}/jobs  (POST list endpoint)
# Teamtailor: https://{subdomain}.teamtailor.com/jobs.rss  → use DOUBOW_JOB_BOARD_RSS_URLS (RSS ingest), not Scrapling HTML
# Max canonical jobs to fetch/persist per Scrapling ingest run (not tied to Adzuna).
# SCRAPLING_INGEST_MAX_JOBS=100

# --- S3: choose ONE setup ---
#
# A) Local MinIO (Docker Compose): use endpoint + MinIO credentials.
#    For API/worker *inside* Compose, ``docker-compose.yml`` overrides this to
#    ``http://minio:9000`` so S3 calls reach the MinIO service. Keep localhost here
#    for running the API on the host against published MinIO ports.
#    Region can stay us-east-1 for MinIO; bucket is created on first upload if missing.
DOUBOW_S3_ENDPOINT_URL=http://localhost:9000
DOUBOW_S3_REGION=us-east-1
DOUBOW_S3_ACCESS_KEY_ID=minioadmin
DOUBOW_S3_SECRET_ACCESS_KEY=minioadmin
DOUBOW_S3_BUCKET_RESUMES=s3-resumes-888687695411
#
# B) AWS S3 (Terraform bucket in eu-west-3): omit endpoint so boto3 uses real AWS.
#    Set region to the bucket region. Either set keys below OR rely on the AWS credential
#    chain (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY, ~/.aws/credentials, AWS_PROFILE, IAM role).
# DOUBOW_S3_ENDPOINT_URL=
# DOUBOW_S3_REGION=eu-west-3
# DOUBOW_S3_ACCESS_KEY_ID=
# DOUBOW_S3_SECRET_ACCESS_KEY=
# DOUBOW_S3_BUCKET_RESUMES=s3-resumes-888687695411

# --- Résumé processing after upload ---
# Default: parse + embed runs automatically on the API after POST /me/resume (BackgroundTasks; no Celery worker needed).
# Set true only if you run a Celery worker and want uploads queued there instead:
# DOUBOW_RESUME_PROCESS_VIA_CELERY=false

# --- Optional: LLM résumé structuring (parsed_json.structured_llm) ---
# DOUBOW_RESUME_LLM_STRUCTURING_ENABLED=false
# DOUBOW_RESUME_LLM_STRUCTURING_MAX_CHARS=12000
# Provider: auto (OpenRouter, then direct Anthropic, then OpenAI), or openrouter|claude|openai
# DOUBOW_RESUME_STRUCTURING_PROVIDER=auto
# DOUBOW_OPENAI_API_KEY=sk-...
# DOUBOW_OPENAI_CHAT_MODEL=gpt-4o-mini
# OpenRouter — Claude (or any model) via https://openrouter.ai (OpenAI-compatible client)
# DOUBOW_OPENROUTER_API_KEY=
# DOUBOW_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# DOUBOW_OPENROUTER_CHAT_MODEL=anthropic/claude-3.5-haiku
# Optional OpenRouter attribution headers (recommended on public apps)
# DOUBOW_OPENROUTER_HTTP_REFERER=https://yoursite.com
# DOUBOW_OPENROUTER_APP_TITLE=DouBow
# Direct Anthropic Messages API (when provider is auto/claude, or no OpenRouter key)
# DOUBOW_ANTHROPIC_API_KEY=sk-ant-...
# DOUBOW_ANTHROPIC_CHAT_MODEL=claude-3-5-haiku-20241022

## Clerk (optional — required when using Clerk sign-in on the web app)
# If set, the API accepts Clerk JWTs on Authorization: Bearer <token>.
# Next.js BFF uses getToken({ template: "doubow-api" }); create that JWT template in Clerk
# with audience equal to DOUBOW_CLERK_AUDIENCE below, and include the primary email claim so
# the API can map users (see app/api/deps.py).
# Production must use a Clerk Production instance/domain; do not ship `*.clerk.accounts.dev`.
DOUBOW_CLERK_JWKS_URL=https://<your-clerk-domain>/.well-known/jwks.json
DOUBOW_CLERK_ISSUER=https://<your-clerk-domain>
DOUBOW_CLERK_AUDIENCE=<your-clerk-audience>

## Phase 3 — outbound sender (optional in dev)
# Prefer Resend (HTTP API): set DOUBOW_RESEND_API_KEY and a verified-domain ``from`` (``DOUBOW_RESEND_FROM`` or
# ``DOUBOW_SMTP_FROM``). When the API key is set, Resend is used instead of SMTP for follow-up reminders,
# dispatch email, and the plain-text “acknowledgement of receipt” email after a successful ``POST /me/resume`` parse.
# See https://resend.com/docs/send-with-python
# DOUBOW_RESEND_API_KEY=re_...
# DOUBOW_RESEND_FROM=Doubow <hello@yourdomain.com>
# On ``POST /auth/signup``, a welcome email is queued (BackgroundTasks) to the new account email when
# Resend or SMTP is configured — delivered from your domain, not through the user's Gmail.
#
# Terraform can create SES domain + DKIM + SMTP IAM user: infra/terraform/ses (see terraform.tfvars.example).
# Vercel + SES: use the same brand domain for the web app (Vercel) and for From: addresses (SES). SES does not run on
# Vercel—the API/Celery worker uses SMTP below. Add SES verification TXT + DKIM CNAMEs wherever DNS for that domain
# lives: Vercel Dashboard → your domain → DNS (if nameservers point to Vercel), or your registrar / Route 53 / Cloudflare.
# Optional — CLI after `vercel login`: scripts/add-ses-dns-vercel.sh (DKIM CNAMEs + DMARC for doubau.vercel.app defaults).
# SES SMTP: verify identity in the same region as DOUBOW_SMTP_HOST. Create SMTP credentials (SES → SMTP settings);
# username/password are shown once. Sandbox: verify recipient emails too, or request production access.
# Region examples: us-east-1 → email-smtp.us-east-1.amazonaws.com | eu-west-3 → email-smtp.eu-west-3.amazonaws.com
# Option A — STARTTLS (default): port 587, DOUBOW_SMTP_USE_TLS=true, DOUBOW_SMTP_USE_SSL=false
# Option B — SSL wrapper: port 465, DOUBOW_SMTP_USE_SSL=true, DOUBOW_SMTP_USE_TLS=false
# DOUBOW_SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# DOUBOW_SMTP_PORT=587
# DOUBOW_SMTP_USER=
# DOUBOW_SMTP_PASSWORD=
# DOUBOW_SMTP_FROM=noreply@yourverifieddomain.com
# DOUBOW_SMTP_USE_TLS=true
# DOUBOW_SMTP_USE_SSL=false
# Tracker follow-up reminder emails: Celery Beat enqueues ``send_followup_reminder_emails`` every 15 minutes (UTC).
# Requires Resend or SMTP + a worker on the ``notify`` queue; the email links to ``/app/tracker`` on the first CORS origin.
# LinkedIn: optional webhook payload when dispatch runs (no official LinkedIn API here).
# DOUBOW_LINKEDIN_DISPATCH_WEBHOOK_URL=https://your-automation.example/hooks/linkedin

## Gmail in-app apply (OAuth — user sends from their mailbox; no Gmail.com tab)
# Redirect URI must match Google Cloud Console (web BFF callback), e.g.:
#   https://<your-vercel-app>/api/me/google/oauth/callback
#   http://localhost:3000/api/me/google/oauth/callback
# DOUBOW_GOOGLE_OAUTH_CLIENT_ID=
# DOUBOW_GOOGLE_OAUTH_CLIENT_SECRET=
# DOUBOW_GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/me/google/oauth/callback
# Optional dedicated Fernet key (44-char url-safe base64). If unset, derives from DOUBOW_JWT_SECRET.
# DOUBOW_OAUTH_TOKEN_FERNET_KEY=
# Unprefixed fallbacks (read if DOUBOW_* unset): GOOGLE_OAUTH_CLIENT_ID, GOOGLE_OAUTH_CLIENT_SECRET,
# GOOGLE_OAUTH_REDIRECT_URI, GOOGLE_OAUTH_TOKEN_FERNET_KEY. GOOGLE_OAUTH_STATE_SECRET is not used
# (OAuth state is a JWT signed with DOUBOW_JWT_SECRET).
# Debug: POST /me/google/send-test-email JSON {"to":"you@example.com"} — same Gmail API stack as application send (requires connected Gmail).
#
## LinkedIn profile sync (OpenID — Sign In with LinkedIn; separate from Clerk login)
# Create a LinkedIn Developer app → Auth tab → OAuth 2.0 redirect URLs must include:
#   https://<your-vercel-app>/api/me/linkedin/oauth/callback
#   http://localhost:3000/api/me/linkedin/oauth/callback
# Enable "Sign In with LinkedIn using OpenID Connect" product; scopes: openid, profile, email.
# DOUBOW_LINKEDIN_OAUTH_CLIENT_ID=
# DOUBOW_LINKEDIN_OAUTH_CLIENT_SECRET=
# DOUBOW_LINKEDIN_OAUTH_REDIRECT_URI=http://localhost:3000/api/me/linkedin/oauth/callback
# Unprefixed fallbacks: LINKEDIN_OAUTH_CLIENT_ID, LINKEDIN_OAUTH_CLIENT_SECRET, LINKEDIN_OAUTH_REDIRECT_URI.

# Admin ingestion (future routes): comma-separated Clerk user ids (`sub`) allowed in production.
# DOUBOW_ADMIN_INGESTION_USER_IDS=user_2abc...,user_2def...

## Railway (production API)
# Public host example: https://doubau-production.up.railway.app — set HTTP service target port to 8080 (Railway PORT).
# scripts/start.sh: PORT="${PORT:-8000}" then uvicorn --port "$PORT". Mismatch (e.g. target 8000 vs listen 8080) → 502.
# DOUBOW_DATABASE_URL / DOUBOW_REDIS_URL: private URLs from Railway Postgres + Redis for the API service only.
