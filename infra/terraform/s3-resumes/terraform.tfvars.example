# Copy to terraform.tfvars (not committed) and adjust.
# Authenticate with AWS using credentials that can create S3 buckets and (optionally) IAM policies:
#   export AWS_PROFILE=your-profile

aws_region = "eu-west-3"

# Must be globally unique. Example pattern with account ID:
resume_bucket_name = "s3-resumes-888687695411"

# Optional: if the app should access S3 through an access point alias, set both.
# Use the alias value as DOUBOW_S3_BUCKET_RESUMES in API/worker env.
# s3_access_point_name  = "doubau-888687695411"
# s3_access_point_alias = "doubau-888687695411-4p8y6mdoq7eqbhic44539kjwqonwqeuw3a-s3alias"

# Must match API object keys (default: resumes/<user_id>/...).
# resume_object_prefix = "resumes"

# Scraped job posting HTML (default: job-html/<hash>.html); IAM allows Get/Put under this prefix.
# job_html_object_prefix = "job-html"

# Recommended for AWS: require TLS (set false only if a broken client cannot use HTTPS).
# iam_enforce_tls = true

# Optional: Terraform-managed least-privilege policy attached to an IAM user (user name only).
# If your user already has S3 access via groups — e.g. BroadAIEngineerAccess with
# AmazonS3FullAccess — leave this empty so Terraform only creates the bucket (no extra policy).
# Example user ARN when you do attach: arn:aws:iam::888687695411:user/aiengineer
grant_s3_access_user_name = ""

# Recommended for Railway/API credentials: create a dedicated least-privilege IAM user
# and access key. The key can only GetObject/PutObject under resumes/* and job-html/*.
# The secret access key is sensitive and will be stored in Terraform state.
# app_iam_user_name          = "doubow-api-s3"
# create_app_iam_user        = true
# create_app_iam_access_key  = true

extra_tags = {
  Environment = "prod"
}
