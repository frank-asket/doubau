# Doubow web (Next.js) — copy to `.env.local` for development.
# Vercel: set the same keys in Project → Settings → Environment Variables.

# Public API origin (no trailing slash). Required on Vercel / staging / production.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Clerk (https://dashboard.clerk.com)
# Local/demo: pk_test_ / sk_test_. Production: pk_live_ / sk_live_ on a custom domain.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional: JWT template name if your Clerk dashboard uses a custom template for FastAPI.
# CLERK_JWT_TEMPLATE=doubow-api

# Optional redirect after sign-in (defaults are fine for most setups).
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/app/dashboard

# Optional: Clerk Billing plan price IDs (see web/README.md).
# NEXT_PUBLIC_CLERK_PLAN_FREE_MONTH=
# NEXT_PUBLIC_CLERK_PLAN_FREE_YEAR=
# NEXT_PUBLIC_CLERK_PLAN_BUSINESS_MONTH=
# NEXT_PUBLIC_CLERK_PLAN_BUSINESS_YEAR=

# Launch checks:
#   npm run launch:check
# Vercel production builds also fail when Clerk/API envs are still dev/local.
