# Doubow web (Next.js) — copy to `.env.local` for development.
# Vercel: set the same keys in Project → Settings → Environment Variables.

# Public API origin (no trailing slash). Required on Vercel / staging / production.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Optional server-only API origin for Docker/internal networks.
# In docker compose, Next.js server-side rendering should use http://api:8000
# while browser/client code keeps NEXT_PUBLIC_API_BASE_URL=http://localhost:8000.
# API_INTERNAL_BASE_URL=http://api:8000

# Clerk (https://dashboard.clerk.com)
# Keys must match: pk_test_ ↔ sk_test_, or pk_live_ ↔ sk_live_ (Vercel Production + *.vercel.app
# can use Development keys; live keys need a custom domain per Clerk).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional: JWT template name if your Clerk dashboard uses a custom template for FastAPI.
# CLERK_JWT_TEMPLATE=doubow-api

# Optional redirect after sign-in (defaults are fine for most setups).
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/app/dashboard

# Optional: Clerk Billing plan price IDs (see web/README.md).
# NEXT_PUBLIC_CLERK_PLAN_FREE_MONTH=
# NEXT_PUBLIC_CLERK_PLAN_FREE_YEAR=
# NEXT_PUBLIC_CLERK_PLAN_BUSINESS_MONTH=
# NEXT_PUBLIC_CLERK_PLAN_BUSINESS_YEAR=

# Optional: override GitHub link in Job Discovery empty-catalog callout (forks).
# NEXT_PUBLIC_LAUNCH_DOCS_URL=https://github.com/you/doubau/blob/main/docs/LAUNCH_WEEK.md

# Optional: show collapsible "Catalog by listing_source" on /app/discovery (staging / demos).
# In local `npm run dev` this panel appears without setting the flag.
# NEXT_PUBLIC_SHOW_CATALOG_SOURCE_DEBUG=true

# Launch checks:
#   npm run launch:check
# Vercel production builds also fail when Clerk/API envs are still dev/local.
